# ─── Public (exposed to browser — only NEXT_PUBLIC_* prefix) ───
NEXT_PUBLIC_SITE_URL=https://sixtynewton.com
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_META_PIXEL_ID=

# ─── Server-only (NEVER NEXT_PUBLIC_) ───
# SMTP for contact-form submissions (nodemailer)
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM="Sixty Newton Website <noreply@60newton.com>"
# Comma-separated list — every address receives a copy.
# Default if unset: info@60newton.com,tarun.s@lapizblue.com
MAIL_TO="info@60newton.com,tarun.s@lapizblue.com"

# Optional: Meta Conversion API (server-side pixel)
META_CAPI_TOKEN=
META_CAPI_PIXEL_ID=

# Optional: rate-limit / spam protection
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
